# ─────────────────────────────────────────────────────────────
#  ctrlPlane — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Ports ─────────────────────────────────────────────────────
# Port the web UI will be accessible on your host machine
WEB_PORT=8080

# ── Image tag ─────────────────────────────────────────────────
# Which GHCR image tag to run. Use 'dev' for latest dev builds.
# Defaults to 'main' (stable). Options: main, dev, sha-xxxxxxx
IMAGE_TAG=main

# ── Security ──────────────────────────────────────────────────
# REQUIRED: Random secret used to encrypt integration credentials at rest.
# Generate with: openssl rand -hex 32
MASTER_SECRET=

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=ctrlPlane
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=ctrlPlane

# ── Logging ───────────────────────────────────────────────────
# Options: fatal, error, warn, info, debug, trace
LOG_LEVEL=info

# ── Optional: external access ────────────────────────────────
# Set this if you're exposing the dashboard via a reverse proxy
# e.g. https://ctrlplane.yourdomain.com
# CORS_ORIGIN=https://ctrlplane.yourdomain.com
